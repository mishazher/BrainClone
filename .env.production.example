# Production Environment Variables

# Database (Postgres + pgvector)
# In production this is Supabase: use the pooler host/port (6543 transaction or
# 5432 session) and ensure the `vector` extension is enabled in the project.
POSTGRES_USER=graphaura
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
POSTGRES_DB=graphaura
# Dedicated database for R2R's own tables (chunks, graph, etc.)
R2R_POSTGRES_DBNAME=r2r

# Neo4j Aura (Free tier)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Google Gemini API — powers BOTH R2R completion/KG-extraction and embeddings
# (via LiteLLM). Single key for the whole pipeline. See r2r-config/config.toml.
GEMINI_API_KEY=your-gemini-api-key-here

# JWT Configuration
JWT_SECRET_KEY=your-very-long-random-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# CORS
CORS_ORIGINS=https://your-frontend-domain.vercel.app,https://your-custom-domain.com

# R2R Configuration (external R2R server; backend connects as a REST client)
R2R_BASE_URL=http://localhost:7272
R2R_CONFIG_PATH=/app/config/config.toml

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=GraphAura
VERSION=0.1.0
DEBUG=false