# Cloud Build upload filter (context = repo root, see cloudbuild.yaml).
# Whitelist: only the pieces the Docker build needs.
/*
!/backend
!/r2r-config
!/cloudbuild.yaml

# Keep secrets and local cruft out of the upload.
backend/.env
backend/.env.*
backend/.venv/
backend/venv/
backend/data/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local-only seed scripts not needed in the image.
backend/seed_neo4j.py
backend/populate_extended_neo4j.py
