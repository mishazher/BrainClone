      "located_in", "lived_in", "visited", "born_in", "died_in",
      "authored", "cited", "mentioned_in", "references",
      "parent_of", "child_of", "part_of", "contains",
      "preceded_by", "followed_by", "concurrent_with",
      "related_to", "similar_to", "opposite_of", "caused_by", "resulted_in"
